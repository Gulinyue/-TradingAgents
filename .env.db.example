# =========================================================
# TradingAgents Database Credentials
# 复制此文件为 .env.db 并填入真实密码
# 不要将 .env.db 提交到版本控制
# =========================================================

# postgres 超级用户密码（容器初始化用）
DB_POSTGRES_PASSWORD=CHANGE_ME_POSTGRES_PASSWORD

# 应用账号密码（schema_v1.sql 中的三个用户）
# 在容器启动后通过以下命令设置:
# docker exec pg18-ta psql -U postgres -d tradingagents -c "ALTER ROLE ta_app_rw WITH PASSWORD 'YOUR_NEW_PASSWORD';"
TA_APP_RW_PASSWORD=CHANGE_ME_TA_APP_RW_PASSWORD
TA_PANEL_RW_PASSWORD=CHANGE_ME_TA_PANEL_RW_PASSWORD
TA_ML_RO_PASSWORD=CHANGE_ME_TA_ML_RO_PASSWORD

# =========================================================
# 连接字符串（供参考）
# =========================================================
# Host: localhost
# Port: 6543
# Database: tradingagents
#
# ta_app_rw:   读、写、序列更新
# ta_panel_rw: 读、写、序列更新
# ta_ml_ro:    只读
#
# 示例 Python 连接:
#   import psycopg2
#   conn = psycopg2.connect(
#       host="localhost", port=6543,
#       dbname="tradingagents", user="ta_app_rw",
#       password=os.getenv("TA_APP_RW_PASSWORD")
#   )
