# LLM Providers (set the one you use)
OPENAI_API_KEY=
GOOGLE_API_KEY=
ANTHROPIC_API_KEY=
XAI_API_KEY=
OPENROUTER_API_KEY=

# MiniMax Anthropic 兼容端点（固定值，勿改）
ANTHROPIC_BASE_URL=https://api.minimaxi.com/anthropic

# Data vendor (Alpha Vantage - free tier available at https://www.alphavantage.co/support/#api-key)
ALPHA_VANTAGE_API_KEY=

# Tushare Pro (中国A股数据)
# 申请地址: https://tushare.pro/register
TUSHARE_TOKEN=

# Ollama (local models - set if using local LLM)
OLLAMA_BASE_URL=http://localhost:11434

# =========================================================
# Database (PostgreSQL 18 + TimescaleDB + pgvector)
# =========================================================
# Docker Compose 启动后，DB_HOST=localhost，端口 6543
# 若在宿主机之外连接，换成容器 IP 或域名
DB_HOST=localhost
DB_PORT=6543
DB_NAME=tradingagents
DB_USER=ta_app_rw
DB_PASSWORD=CHANGE_ME_TA_APP_RW_PASSWORD

# 面板账号（读写权限）
DB_PANEL_USER=ta_panel_rw
DB_PANEL_PASSWORD=CHANGE_ME_TA_PANEL_RW_PASSWORD

# ML 宿主机只读账号
DB_ML_USER=ta_ml_ro
DB_ML_PASSWORD=CHANGE_ME_TA_ML_RO_PASSWORD

# TradingAgents Runner 加载 .env 的路径（通常为项目根目录）
ENV_FILE_PATH=.env
